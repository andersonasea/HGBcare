# Firebase — Projet HBG Care (hbgcare)
# Récupérez ces valeurs dans la Console Firebase : https://console.firebase.google.com
# Sélectionnez votre projet "hbgcare" → Paramètres du projet (engrenage) → Général → Vos applications

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=hbgcare.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=hbgcare
VITE_FIREBASE_STORAGE_BUCKET=hbgcare.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
